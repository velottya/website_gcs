<?xml version="1.0" encoding="UTF-8"?>
<!--
  Konfigurasi IIS untuk website_gcs.
  Catatan: handler PHP (FastCGI) didaftarkan di tingkat server IIS (lewat PHP Manager /
  Web Platform Installer), jadi tidak di-hardcode di sini agar tidak bergantung pada
  path php-cgi.exe yang berbeda tiap server. Lihat PANDUAN_DEPLOY_IIS.md.
-->
<configuration>
  <system.webServer>

    <!-- Halaman default saat mengakses root folder -->
    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>

    <!-- Jangan tampilkan daftar isi folder -->
    <directoryBrowse enabled="false" />

    <security>
      <requestFiltering>
        <!-- Izinkan total unggahan hingga ~50 MB (beberapa lampiran @maks 5MB).
             PHP sendiri juga dibatasi upload_max_filesize/post_max_size di php.ini server. -->
        <requestLimits maxAllowedContentLength="52428800" />

        <!-- Blokir akses HTTP langsung ke file/folder sensitif -->
        <hiddenSegments>
          <add segment="config.php" />
          <add segment="config.example.php" />
          <add segment="db.php" />
          <add segment="database" />
        </hiddenSegments>

        <!-- Blokir file yang tidak untuk publik -->
        <fileExtensions>
          <add fileExtension=".sql" allowed="false" />
          <add fileExtension=".md" allowed="false" />
        </fileExtensions>
      </requestFiltering>
    </security>

  </system.webServer>
</configuration>
